# 阿里云 OSS 部署配置（模板）
# ----------------------------------------
# 复制本文件为 _config.deploy.yml，填入真实 AccessKey 后即可部署。
# _config.deploy.yml 已被 .gitignore 排除，不会被提交。
#
# AccessKey 来自 RAM 子账号（不要用主账号 AccessKey）：
# 阿里云控制台 → RAM 访问控制 → 用户 → 创建用户（OpenAPI 调用）
# 授权策略：AliyunOSSFullAccess（或自定义仅限 guiwz-blog 的策略）

deploy:
  type: ali-oss
  bucket: guiwz-blog
  region: oss-cn-shanghai
  accessKeyId: 'LTAI5tXXXXXXXXXXXXXX'
  accessKeySecret: 'xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx'
